{
    "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
    "vcs": {
        "enabled": false,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "includes": [
            "**/*.{json,ts,js,svelte}",
            "!**/dist",
            "!**/node_modules",
            "!**/.belte",
            "!**/routes.gen.ts"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "semicolons": "asNeeded",
            "trailingCommas": "all",
            "arrowParentheses": "always"
        }
    },
    "html": {
        "formatter": {
            "bracketSameLine": true,
            "indentScriptAndStyle": false,
            "enabled": true,
            "whitespaceSensitivity": "css"
        },
        "experimentalFullSupportEnabled": true
    },
    "css": {
        "formatter": {
            "enabled": true
        },
        "parser": {
            "tailwindDirectives": true
        }
    },
    "json": {
        "formatter": {
            "indentWidth": 4,
            "trailingCommas": "none"
        }
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "off"
            },
            "style": {
                "useImportType": "error",
                "useNodejsImportProtocol": "error"
            }
        }
    },
    "overrides": [
        {
            "includes": ["**/*.test.ts"],
            "linter": {
                "rules": {
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
