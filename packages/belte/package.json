{
    "name": "belte",
    "version": "0.0.1",
    "type": "module",
    "exports": {
        "./types/*": "./src/lib/types/*.ts",
        "./server/*": "./src/lib/server/*.ts",
        "./server": "./src/lib/server/server.ts",
        "./client/*": "./src/lib/client/*.ts",
        "./shared/*": "./src/lib/shared/*.ts",
        "./rpc/*": "./src/lib/rpc/*.ts",
        "./cache": "./src/lib/shared/cache.ts",
        "./nav": "./src/lib/client/nav.svelte.ts",
        "./build": "./src/build.ts",
        "./compile": "./src/compile.ts",
        "./preload": "./src/preload.ts",
        "./svelte-plugin": "./src/sveltePlugin.ts",
        "./resolver-plugin": "./src/belteResolverPlugin.ts"
    },
    "bin": {
        "belte": "./bin/belte.ts"
    },
    "files": [
        "src",
        "bin",
        "template"
    ],
    "peerDependencies": {
        "svelte": "^5.0.0",
        "bun-plugin-tailwind": "*",
        "tailwindcss": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "bun-plugin-tailwind": {
            "optional": true
        },
        "tailwindcss": {
            "optional": true
        }
    },
    "devDependencies": {
        "bun-plugin-tailwind": "latest",
        "tailwindcss": "^4.0.0"
    }
}
