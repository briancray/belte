{
    "name": "belte",
    "version": "0.0.1",
    "type": "module",
    "exports": {
        "./server": "./src/lib/server/index.ts",
        "./browser": "./src/lib/browser/index.ts",
        "./server/rpc/*": "./src/lib/server/rpc/*.ts",
        "./server/sockets/*": "./src/lib/server/sockets/*.ts",
        "./browser/*": "./src/lib/browser/*.ts",
        "./build": "./src/build.ts",
        "./compile": "./src/compile.ts",
        "./preload": "./src/preload.ts",
        "./svelte-plugin": "./src/sveltePlugin.ts",
        "./resolver-plugin": "./src/belteResolverPlugin.ts",
        "./tsconfig": "./tsconfig.app.json"
    },
    "bin": {
        "belte": "./bin/belte.ts"
    },
    "files": [
        "src",
        "bin",
        "template",
        "tsconfig.app.json"
    ],
    "peerDependencies": {
        "svelte": "^5.0.0",
        "bun-plugin-tailwind": "*",
        "tailwindcss": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "bun-plugin-tailwind": {
            "optional": true
        },
        "tailwindcss": {
            "optional": true
        }
    },
    "devDependencies": {
        "bun-plugin-tailwind": "latest",
        "tailwindcss": "^4.0.0"
    }
}
