{
    // belte ships raw TS, so consumer tsconfig flags type-check it (the 0.24.2
    // and parseTraceparent breakages). This probe type-checks exactly what npm
    // ships (src + bin; template needs a scaffolded app around it and is covered
    // by the scaffold-smoke job) under the tsconfig scaffolded apps get, plus
    // noUncheckedIndexedAccess — the strictest indexing flag consumers enable
    // that `strict` doesn't imply. Tests stay on the repo's own tsconfig.
    "extends": "./tsconfig.app.json",
    "compilerOptions": {
        "noUncheckedIndexedAccess": true,
        // Already clean on shipped source — locked in here at zero cost so they
        // stay that way. exactOptionalPropertyTypes (40 errors) and
        // noPropertyAccessFromIndexSignature (58) are the measured cleanup passes
        // still outstanding; add them only with that budget.
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitOverride": true
    },
    "include": ["src/**/*.ts", "bin/**/*.ts"]
}
