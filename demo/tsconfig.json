{
    "extends": "@belte/belte/tsconfig",
    "include": ["src/**/*.ts", "src/**/*.svelte"],
    "compilerOptions": {
        "paths": {
            "$server": ["./src/server"],
            "$server/*": ["./src/server/*"],
            "$browser": ["./src/browser"],
            "$browser/*": ["./src/browser/*"],
            "$shared": ["./src/shared"],
            "$shared/*": ["./src/shared/*"],
            "$mcp": ["./src/mcp"],
            "$mcp/*": ["./src/mcp/*"],
            "$cli": ["./src/cli"],
            "$cli/*": ["./src/cli/*"]
        }
    }
}
