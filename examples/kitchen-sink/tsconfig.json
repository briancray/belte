{
    "extends": "belte/tsconfig",
    "include": ["src/**/*.ts", "src/**/*.svelte"],
    "compilerOptions": {
        "paths": {
            "$pages": ["./src/pages"],
            "$pages/*": ["./src/pages/*"],
            "$rpc": ["./src/server/rpc"],
            "$rpc/*": ["./src/server/rpc/*"],
            "$sockets": ["./src/server/sockets"],
            "$sockets/*": ["./src/server/sockets/*"],
            "$prompts": ["./src/server/prompts"],
            "$prompts/*": ["./src/server/prompts/*"],
            "$lib": ["./src/lib"],
            "$lib/*": ["./src/lib/*"]
        }
    }
}
