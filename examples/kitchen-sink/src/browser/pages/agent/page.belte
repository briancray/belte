<script>
import CodeBlock from '$browser/CodeBlock.belte'
import Layout from '$browser/Layout.belte'
import { chat } from '$server/rpc/chat.ts'

let messages = state([])
let toolCalls = state([])
let draft = state('Which tools can you call? Use one and show me the result.')
let streaming = state(false)
let error = state(undefined)

/* POST the running transcript, then read the JSONL response frame-by-frame,
   folding each AgentFrame into the live assistant turn. */
async function send() {
    const text = draft.trim()
    if (!text || streaming) {
        return
    }
    error = undefined
    toolCalls = []
    const history = [...messages, { id: crypto.randomUUID(), role: 'user', text }]
    draft = ''
    messages = [...history, { id: crypto.randomUUID(), role: 'assistant', text: '' }]
    streaming = true
    try {
        const response = await chat.raw({ messages: history })
        if (!response.ok || !response.body) {
            throw new Error(`HTTP ${response.status}`)
        }
        const reader = response.body.pipeThrough(new TextDecoderStream()).getReader()
        let buffer = ''
        while (true) {
            const { value, done } = await reader.read()
            if (done) {
                break
            }
            buffer += value
            const lines = buffer.split('\n')
            buffer = lines.pop() ?? ''
            for (const line of lines) {
                if (line) {
                    apply(JSON.parse(line))
                }
            }
        }
    } catch (cause) {
        error = cause instanceof Error ? cause.message : String(cause)
    } finally {
        streaming = false
    }
}

/* Fold one frame into the live assistant turn — immutable updates so the doc cell
   re-renders (no nested-mutation reliance). */
function apply(frame) {
    if ('$error' in frame) {
        error = frame.$error
        return
    }
    if (frame.type === 'text') {
        const lastIndex = messages.length - 1
        messages = messages.map((message, index) =>
            index === lastIndex && message.role === 'assistant'
                ? { ...message, text: message.text + frame.delta }
                : message,
        )
    } else if (frame.type === 'tool_use') {
        const lastIndex = messages.length - 1
        messages = messages.map((message, index) =>
            index === lastIndex && message.role === 'assistant' && message.text && !message.text.endsWith('\n')
                ? { ...message, text: message.text + '\n\n' }
                : message,
        )
        toolCalls = [...toolCalls, { id: frame.id, name: frame.name, input: frame.input }]
    } else if (frame.type === 'tool_result') {
        toolCalls = toolCalls.map((call) => (call.id === frame.id ? { ...call, ok: frame.ok } : call))
    }
}
</script>

<Layout>
    <h1 class="text-3xl font-bold">agent</h1>
    <p class="mt-2 text-slate-600">
        <code class="font-mono">agent(engine, messages)</code> runs a model against this app's own gated MCP
        surface and streams back <code class="font-mono">AgentFrame</code>s. Here the
        <code class="font-mono">@belte/claude-code</code> engine drives Claude Code over the app's
        schema-bearing verbs.
    </p>
    <p class="mt-2 text-xs text-slate-500">
        Permission is fixed server-side: <code class="font-mono">tools: []</code> drops every Claude Code
        built-in and <code class="font-mono">dontAsk</code> denies anything not in the
        <code class="font-mono">allow</code> list, so the agent can only call
        <code class="font-mono">getProduct</code> and <code class="font-mono">getRates</code>.
    </p>

    <section class="mt-6 rounded-lg border border-slate-200 bg-white p-5">
        <h2 class="text-sm font-semibold">Chat — try it</h2>

        <template if={messages.length > 0}>
            <ul class="mt-3 space-y-2">
                <template each={messages} as="message" key="message.id">
                    <li class="text-sm">
                        <span class={`mr-2 font-mono text-xs uppercase ${message.role === 'user' ? 'text-slate-400' : 'text-indigo-500'}`}>{message.role}</span>
                        <span class="whitespace-pre-wrap text-slate-800">{message.text}</span>
                    </li>
                </template>
            </ul>
        </template>

        <template if={toolCalls.length > 0}>
            <div class="mt-3 rounded-md border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-semibold text-slate-500">tool calls</p>
                <ul class="mt-1 space-y-1 font-mono text-xs text-slate-700">
                    <template each={toolCalls} as="call" key="call.id">
                        <li>
                            <span class={`${call.ok === undefined ? 'text-slate-400' : call.ok ? 'text-emerald-600' : 'text-red-600'}`}>{call.ok === undefined ? '…' : call.ok ? '✓' : '✗'}</span>
                            {call.name} ({JSON.stringify(call.input)})
                        </li>
                    </template>
                </ul>
            </div>
        </template>

        <form class="mt-4 flex gap-2" onsubmit={(event) => { event.preventDefault(); void send() }}>
            <input type="text" bind:value={draft} disabled={streaming} placeholder="Ask the agent…" class="flex-1 rounded-md border border-slate-300 px-3 py-1.5 text-sm outline-none focus:border-slate-500 disabled:opacity-60" />
            <button type="submit" disabled={streaming} class="rounded-md bg-slate-900 px-4 py-1.5 text-sm text-white hover:bg-slate-700 disabled:opacity-60">{streaming ? 'streaming…' : 'send'}</button>
        </form>

        <template if={error}>
            <p class="mt-3 text-sm text-red-600">{error}</p>
        </template>
    </section>

    <section class="mt-6 space-y-3">
        <CodeBlock title="src/server/rpc/chat.ts" code={`import { agent } from '@belte/belte/server/agent'
import { jsonl } from '@belte/belte/server/jsonl'
import { POST } from '@belte/belte/server/POST'
import { engine } from '@belte/claude-code'

const chatEngine = engine({
    tools: [],
    permissions: {
        defaultMode: 'dontAsk',
        allow: ['mcp__kitchen_sink__getProduct', 'mcp__kitchen_sink__getRates'],
    },
})

export const chat = POST(({ messages }) => jsonl(agent(chatEngine, messages)))`} />
    </section>
</Layout>
