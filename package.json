{
    "name": "belte-workspace",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "format": "biome check --write --linter-enabled=false",
        "lint": "biome lint",
        "test": "bun test ./packages && for d in examples/*/; do if [ -d \"$d/test\" ]; then (cd \"$d\" && bun test) || exit 1; fi; done",
        "check": "biome check --write",
        "typecheck": "tsc -p packages/belte/tsconfig.json && tsc -p packages/belte/tsconfig.consumer.json",
        "changeset": "changeset",
        "version-packages": "bun run scripts/autofillChangesets.ts && changeset version && bun run scripts/syncRootChangelog.ts",
        "release": "changeset publish"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.29.7",
        "@types/bun": "latest",
        "svelte": "^5.56.2",
        "typescript": "^6.0.3"
    }
}
